  AND id(n26) <> id(n29)
  AND id(n26) <> id(n30)
  AND id(n26) <> id(n31)
  AND id(n27) <> id(n28)
  AND id(n27) <> id(n29)
  AND id(n27) <> id(n30)
  AND id(n27) <> id(n31)
  AND id(n28) <> id(n29)
  AND id(n28) <> id(n30)
  AND id(n28) <> id(n31)
  AND id(n29) <> id(n30)
  AND id(n29) <> id(n31)
  AND id(n30) <> id(n31)
RETURN count(*) AS count;
